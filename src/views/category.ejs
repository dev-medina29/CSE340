<%- include('partials/header') %>
    <main>
        <h1>
            <%= title %>
        </h1>
        <h2>
            <%= categoryDetails.name %>
        </h2>
        <p><strong>Projects in this Category:</strong></p>
        <ul>
            <% projectsForCategory.forEach(project=> { %>
                <li>
                    <a href="/project/<%= project.project_id %>">
                        <%= project.title %>
                    </a>
                </li>
                <% }); %>
        </ul>

    </main>
    <%- include('partials/footer') %>